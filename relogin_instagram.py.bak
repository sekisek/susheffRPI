import asyncio
from pathlib import Path
from playwright.async_api import async_playwright

BASE = Path.home() / "social-bot"
PROFILE_DIR = BASE / "profiles" / "instagram"


async def main():
    PROFILE_DIR.mkdir(parents=True, exist_ok=True)

    async with async_playwright() as p:
        context = await p.chromium.launch_persistent_context(
            user_data_dir=str(PROFILE_DIR),
            headless=False,
            viewport={"width": 1440, "height": 1000},
            args=["--start-maximized"],
        )

        page = context.pages[0] if context.pages else await context.new_page()
        await page.goto("https://www.instagram.com/", wait_until="domcontentloaded")

        print("\nManual Instagram re-login mode.")
        print("Log in, solve anything needed, make sure home page is loaded.")
        print("Then press Enter here in the terminal to save and close.\n")
        input()

        await context.close()


if __name__ == "__main__":
    asyncio.run(main())

